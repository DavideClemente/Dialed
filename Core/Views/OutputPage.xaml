<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="AudioMixerWin.Core.Views.OutputPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:loc="using:AudioMixerWin.Core.Services"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer>
        <!-- Single capped column: content stretches (so the two position cards
             split the width equally) but never grows past a readable width,
             and stays left-aligned on wide windows. -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" MaxWidth="808" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
        <StackPanel Grid.Column="0" Padding="24,20,24,24" Spacing="16">

            <StackPanel Spacing="2" Margin="0,0,0,4">
                <TextBlock Text="{loc:Loc Key=Output_Title}" Style="{StaticResource PageTitleStyle}" />
                <TextBlock Text="{loc:Loc Key=Output_Caption}" Style="{StaticResource SectionCaptionStyle}" />
            </StackPanel>

            <!-- The two switch positions, each with its own device picker -->
            <Grid ColumnSpacing="14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- Position A -->
                <Border Grid.Column="0" Style="{StaticResource CardStyle}"
                        BorderBrush="{x:Bind ViewModel.IsAActive, Mode=OneWay,
                                      Converter={StaticResource SelectedToBorderBrush}}"
                        BorderThickness="{x:Bind ViewModel.IsAActive, Mode=OneWay,
                                      Converter={StaticResource SelectedToBorderThickness}}">
                    <StackPanel Spacing="12">
                        <Grid>
                            <TextBlock Text="{loc:Loc Key=Output_PosA}"
                                       Style="{StaticResource FieldLabelStyle}"
                                       VerticalAlignment="Center" HorizontalAlignment="Left" />
                            <FontIcon Glyph="{x:Bind ViewModel.AIconGlyph, Mode=OneWay}"
                                      FontSize="18" HorizontalAlignment="Right"
                                      Foreground="{StaticResource TextTertiaryBrush}" />
                        </Grid>

                        <ComboBox HorizontalAlignment="Stretch"
                                  PlaceholderText="{loc:Loc Key=Output_SelectDevice}"
                                  ItemsSource="{x:Bind ViewModel.DevicesForA}"
                                  DisplayMemberPath="Name"
                                  SelectedItem="{x:Bind ViewModel.SelectedDeviceA, Mode=TwoWay}" />

                        <Grid MinHeight="32">
                            <Border Background="{StaticResource AccentSubtleBrush}"
                                    BorderBrush="{StaticResource AccentStrokeBrush}" BorderThickness="1"
                                    CornerRadius="20" Padding="10,4" HorizontalAlignment="Left"
                                    VerticalAlignment="Center"
                                    Visibility="{x:Bind ViewModel.IsAActive, Mode=OneWay,
                                                 Converter={StaticResource BoolToVisible}}">
                                <StackPanel Orientation="Horizontal" Spacing="7">
                                    <Ellipse Width="7" Height="7" Fill="{StaticResource AccentBrush}"
                                             VerticalAlignment="Center" />
                                    <TextBlock Text="{loc:Loc Key=Output_Active}"
                                               Foreground="{StaticResource AccentTextBrush}" FontSize="11" />
                                </StackPanel>
                            </Border>
                            <Button Content="{loc:Loc Key=Output_SetActive}"
                                    Command="{x:Bind ViewModel.ActivateACommand}"
                                    FontSize="12" Padding="12,5" CornerRadius="8" BorderThickness="1"
                                    HorizontalAlignment="Left" VerticalAlignment="Center"
                                    Visibility="{x:Bind ViewModel.IsAActive, Mode=OneWay,
                                                 Converter={StaticResource InverseBoolToVisible}}" />
                        </Grid>
                    </StackPanel>
                </Border>

                <FontIcon Grid.Column="1" Glyph="&#xE8AB;" FontSize="20"
                          Foreground="{StaticResource TextDisabledBrush}" VerticalAlignment="Center" />

                <!-- Position B -->
                <Border Grid.Column="2" Style="{StaticResource CardStyle}"
                        BorderBrush="{x:Bind ViewModel.IsBActive, Mode=OneWay,
                                      Converter={StaticResource SelectedToBorderBrush}}"
                        BorderThickness="{x:Bind ViewModel.IsBActive, Mode=OneWay,
                                      Converter={StaticResource SelectedToBorderThickness}}">
                    <StackPanel Spacing="12">
                        <Grid>
                            <TextBlock Text="{loc:Loc Key=Output_PosB}"
                                       Style="{StaticResource FieldLabelStyle}"
                                       VerticalAlignment="Center" HorizontalAlignment="Left" />
                            <FontIcon Glyph="{x:Bind ViewModel.BIconGlyph, Mode=OneWay}"
                                      FontSize="18" HorizontalAlignment="Right"
                                      Foreground="{StaticResource TextTertiaryBrush}" />
                        </Grid>

                        <ComboBox HorizontalAlignment="Stretch"
                                  PlaceholderText="{loc:Loc Key=Output_SelectDevice}"
                                  ItemsSource="{x:Bind ViewModel.DevicesForB}"
                                  DisplayMemberPath="Name"
                                  SelectedItem="{x:Bind ViewModel.SelectedDeviceB, Mode=TwoWay}" />

                        <Grid MinHeight="32">
                            <Border Background="{StaticResource AccentSubtleBrush}"
                                    BorderBrush="{StaticResource AccentStrokeBrush}" BorderThickness="1"
                                    CornerRadius="20" Padding="10,4" HorizontalAlignment="Left"
                                    VerticalAlignment="Center"
                                    Visibility="{x:Bind ViewModel.IsBActive, Mode=OneWay,
                                                 Converter={StaticResource BoolToVisible}}">
                                <StackPanel Orientation="Horizontal" Spacing="7">
                                    <Ellipse Width="7" Height="7" Fill="{StaticResource AccentBrush}"
                                             VerticalAlignment="Center" />
                                    <TextBlock Text="{loc:Loc Key=Output_Active}"
                                               Foreground="{StaticResource AccentTextBrush}" FontSize="11" />
                                </StackPanel>
                            </Border>
                            <Button Content="{loc:Loc Key=Output_SetActive}"
                                    Command="{x:Bind ViewModel.ActivateBCommand}"
                                    FontSize="12" Padding="12,5" CornerRadius="8" BorderThickness="1"
                                    HorizontalAlignment="Left" VerticalAlignment="Center"
                                    Visibility="{x:Bind ViewModel.IsBActive, Mode=OneWay,
                                                 Converter={StaticResource InverseBoolToVisible}}" />
                        </Grid>
                    </StackPanel>
                </Border>
            </Grid>

            <TextBlock Text="{x:Bind ViewModel.StatusText, Mode=OneWay}"
                       Foreground="{StaticResource TextTertiaryBrush}" FontSize="12" TextWrapping="Wrap"
                       Visibility="{x:Bind ViewModel.StatusText, Mode=OneWay,
                                    Converter={StaticResource StringToVisible}}" />

            <StackPanel Orientation="Horizontal" Spacing="8">
                <FontIcon Glyph="&#xE946;" FontSize="13" Foreground="{StaticResource TextDisabledBrush}" />
                <TextBlock Text="{loc:Loc Key=Output_ManualHint}"
                           Style="{StaticResource FieldHelpStyle}" VerticalAlignment="Center" />
            </StackPanel>

        </StackPanel>
        </Grid>
    </ScrollViewer>
</Page>
