<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="AudioMixerWin.Core.Views.OutputPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:loc="using:AudioMixerWin.Core.Services"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Page.Resources>
        <SolidColorBrush x:Key="ButtonBackground" Color="#121212"/>
        <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="#181818"/>
        <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="#0E0E0E"/>
        <SolidColorBrush x:Key="ButtonBorderBrush" Color="#242424"/>
        <SolidColorBrush x:Key="ButtonBorderBrushPointerOver" Color="#383838"/>
        <SolidColorBrush x:Key="ButtonBorderBrushPressed" Color="#1E1E1E"/>
        <SolidColorBrush x:Key="ButtonForeground" Color="#E0E0E0"/>
        <SolidColorBrush x:Key="ButtonForegroundPointerOver" Color="#F0F0F0"/>
        <SolidColorBrush x:Key="ButtonForegroundPressed" Color="#A0A0A0"/>
    </Page.Resources>

    <ScrollViewer>
        <StackPanel Padding="24" Spacing="16">

            <TextBlock Text="{loc:Loc Key=Output_Title}" FontSize="20" FontWeight="SemiBold"
                       FontFamily="Segoe UI Variable Display" Foreground="#E0E0E0" />

            <TextBlock Text="{loc:Loc Key=Output_Caption}"
                       Foreground="#808080" FontSize="12" Margin="0,-8,0,0" />

            <!-- Switch position hero: two tappable cards (manual override) -->
            <Border Background="#121212" BorderBrush="#242424" BorderThickness="1"
                    CornerRadius="10" Padding="18">
                <StackPanel Spacing="14">
                    <TextBlock Text="{loc:Loc Key=Output_SwitchPosition}" Foreground="#6E6E6E" FontSize="11" />
                    <Grid ColumnSpacing="14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <!-- Position A -->
                        <Button Grid.Column="0" HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Stretch" Padding="14"
                                CornerRadius="9" Background="#141414"
                                Command="{x:Bind ViewModel.ActivateACommand}"
                                BorderBrush="{x:Bind ViewModel.IsAActive, Mode=OneWay,
                                              Converter={StaticResource SelectedToBorderBrush}}"
                                BorderThickness="{x:Bind ViewModel.IsAActive, Mode=OneWay,
                                              Converter={StaticResource SelectedToBorderThickness}}">
                            <StackPanel Spacing="10">
                                <Grid>
                                    <Border Background="#0F1A15" CornerRadius="20" Padding="8,3"
                                            HorizontalAlignment="Left"
                                            Visibility="{x:Bind ViewModel.IsAActive, Mode=OneWay,
                                                         Converter={StaticResource BoolToVisible}}">
                                        <TextBlock Text="{loc:Loc Key=Output_PosA_Active}" Foreground="#8FE0BE" FontSize="11" />
                                    </Border>
                                    <TextBlock Text="{loc:Loc Key=Output_PosA}" Foreground="#888" FontSize="11"
                                               HorizontalAlignment="Left"
                                               Visibility="{x:Bind ViewModel.IsAActive, Mode=OneWay,
                                                            Converter={StaticResource InverseBoolToVisible}}" />
                                    <FontIcon Glyph="{x:Bind ViewModel.AIconGlyph, Mode=OneWay}"
                                              FontSize="18" HorizontalAlignment="Right"
                                              Foreground="#9A9A9A" />
                                </Grid>
                                <TextBlock Text="{x:Bind ViewModel.ADeviceName, Mode=OneWay}"
                                           Foreground="#F2F2F2" FontSize="15" FontWeight="SemiBold"
                                           TextTrimming="CharacterEllipsis" />
                            </StackPanel>
                        </Button>

                        <FontIcon Grid.Column="1" Glyph="&#xE8AB;" FontSize="20"
                                  Foreground="#4A4A4A" VerticalAlignment="Center" />

                        <!-- Position B -->
                        <Button Grid.Column="2" HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Stretch" Padding="14"
                                CornerRadius="9" Background="#141414"
                                Command="{x:Bind ViewModel.ActivateBCommand}"
                                BorderBrush="{x:Bind ViewModel.IsBActive, Mode=OneWay,
                                              Converter={StaticResource SelectedToBorderBrush}}"
                                BorderThickness="{x:Bind ViewModel.IsBActive, Mode=OneWay,
                                              Converter={StaticResource SelectedToBorderThickness}}">
                            <StackPanel Spacing="10">
                                <Grid>
                                    <Border Background="#0F1A15" CornerRadius="20" Padding="8,3"
                                            HorizontalAlignment="Left"
                                            Visibility="{x:Bind ViewModel.IsBActive, Mode=OneWay,
                                                         Converter={StaticResource BoolToVisible}}">
                                        <TextBlock Text="{loc:Loc Key=Output_PosB_Active}" Foreground="#8FE0BE" FontSize="11" />
                                    </Border>
                                    <TextBlock Text="{loc:Loc Key=Output_PosB}" Foreground="#888" FontSize="11"
                                               HorizontalAlignment="Left"
                                               Visibility="{x:Bind ViewModel.IsBActive, Mode=OneWay,
                                                            Converter={StaticResource InverseBoolToVisible}}" />
                                    <FontIcon Glyph="{x:Bind ViewModel.BIconGlyph, Mode=OneWay}"
                                              FontSize="18" HorizontalAlignment="Right"
                                              Foreground="#9A9A9A" />
                                </Grid>
                                <TextBlock Text="{x:Bind ViewModel.BDeviceName, Mode=OneWay}"
                                           Foreground="#F2F2F2" FontSize="15" FontWeight="SemiBold"
                                           TextTrimming="CharacterEllipsis" />
                            </StackPanel>
                        </Button>
                    </Grid>

                    <TextBlock Text="{x:Bind ViewModel.StatusText, Mode=OneWay}"
                               Foreground="#9A9A9A" FontSize="12" TextWrapping="Wrap"
                               Visibility="{x:Bind ViewModel.StatusText, Mode=OneWay,
                                            Converter={StaticResource StringToVisible}}" />
                </StackPanel>
            </Border>

            <TextBlock Text="{loc:Loc Key=Output_AssignHint}" Foreground="#6E6E6E"
                       FontSize="11" Margin="0,4,0,0" />

            <Grid ColumnSpacing="14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Background="#121212" BorderBrush="#242424"
                        BorderThickness="1" CornerRadius="9" Padding="14">
                    <StackPanel Spacing="8">
                        <TextBlock Text="{loc:Loc Key=Output_PosA}" Foreground="#9A9A9A" FontSize="12" />
                        <ComboBox HorizontalAlignment="Stretch" PlaceholderText="{loc:Loc Key=Output_SelectDevice}"
                                  ItemsSource="{x:Bind ViewModel.DevicesForA}"
                                  DisplayMemberPath="Name"
                                  SelectedItem="{x:Bind ViewModel.SelectedDeviceA, Mode=TwoWay}" />
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Background="#121212" BorderBrush="#242424"
                        BorderThickness="1" CornerRadius="9" Padding="14">
                    <StackPanel Spacing="8">
                        <TextBlock Text="{loc:Loc Key=Output_PosB}" Foreground="#9A9A9A" FontSize="12" />
                        <ComboBox HorizontalAlignment="Stretch" PlaceholderText="{loc:Loc Key=Output_SelectDevice}"
                                  ItemsSource="{x:Bind ViewModel.DevicesForB}"
                                  DisplayMemberPath="Name"
                                  SelectedItem="{x:Bind ViewModel.SelectedDeviceB, Mode=TwoWay}" />
                    </StackPanel>
                </Border>
            </Grid>

            <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,4,0,0">
                <FontIcon Glyph="&#xE946;" FontSize="13" Foreground="#6E6E6E" />
                <TextBlock Text="{loc:Loc Key=Output_ManualHint}"
                           Foreground="#6E6E6E" FontSize="11" VerticalAlignment="Center" />
            </StackPanel>

        </StackPanel>
    </ScrollViewer>
</Page>
