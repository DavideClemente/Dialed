<UserControl
    x:Class="AudioMixerWin.Core.Controls.KnobCard"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:loc="using:AudioMixerWin.Core.Services"
    PointerPressed="OnPointerPressed"
    PointerMoved="OnPointerMoved"
    PointerReleased="OnPointerReleased"
    PointerCaptureLost="OnPointerCaptureLost">

    <Border CornerRadius="14" BorderThickness="1" Margin="8"
            Background="{StaticResource SurfaceCardBrush}"
            BorderBrush="{StaticResource StrokeDefaultBrush}">

        <Grid Opacity="{x:Bind ConvertOfflineToOpacity(Channel.IsOffline), Mode=OneWay}">

            <!-- Top white shimmer line (theme signature) -->
            <Border VerticalAlignment="Top" Height="1" CornerRadius="14,14,0,0">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#00FFFFFF" Offset="0"/>
                        <GradientStop Color="#18FFFFFF" Offset="0.25"/>
                        <GradientStop Color="#18FFFFFF" Offset="0.75"/>
                        <GradientStop Color="#00FFFFFF" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
            </Border>

            <StackPanel Padding="16,15,16,16">

                <!-- Header: tinted icon + name + chips, gear on the right -->
                <Grid>
                    <StackPanel Orientation="Horizontal" Spacing="11" VerticalAlignment="Center"
                                HorizontalAlignment="Left">

                        <!-- App icon container, tinted with the app's dominant color -->
                        <Border Width="40" Height="40" CornerRadius="10" BorderThickness="1"
                                Background="{x:Bind GetAccentTintBrush(Channel.AccentColor), Mode=OneWay}"
                                BorderBrush="{x:Bind GetAccentBorderBrush(Channel.AccentColor), Mode=OneWay}">
                            <Grid>
                                <FontIcon Glyph="&#xE767;"
                                          FontSize="20"
                                          Foreground="{StaticResource TextDisabledBrush}"
                                          Visibility="{x:Bind ConvertIconFallbackToVisibility(Channel.IconSource), Mode=OneWay}"
                                          HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                <Image Source="{x:Bind Channel.IconSource, Mode=OneWay}"
                                       Width="28" Height="28"
                                       Visibility="{x:Bind ConvertIconToVisibility(Channel.IconSource), Mode=OneWay}"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>

                        <!-- Name + knob label badge -->
                        <StackPanel VerticalAlignment="Center" Spacing="5">
                            <TextBlock
                                Text="{x:Bind Channel.DisplayName, Mode=OneWay}"
                                FontSize="15"
                                FontWeight="SemiBold"
                                FontFamily="Segoe UI Variable Display"
                                Foreground="{StaticResource TextPrimaryBrush}"
                                CharacterSpacing="-15"/>
                            <StackPanel Orientation="Horizontal" Spacing="5">
                                <Border Style="{StaticResource InsetChipStyle}" HorizontalAlignment="Left">
                                    <TextBlock
                                        Style="{StaticResource MonoBadgeTextStyle}"
                                        Text="{x:Bind Channel.KnobLabel, Mode=OneWay}"
                                        CharacterSpacing="100"/>
                                </Border>
                                <Border Background="{StaticResource WarningSubtleBrush}" CornerRadius="4" Padding="5,2"
                                        Visibility="{x:Bind ConvertDisconnectedToVisibility(Channel.IsSerialConnected), Mode=OneWay}"
                                        ToolTipService.ToolTip="{loc:Loc Key=Knob_Offline_Tip}">
                                    <TextBlock
                                        Style="{StaticResource MonoBadgeTextStyle}"
                                        Text="{loc:Loc Key=Knob_Offline}"
                                        Foreground="{StaticResource WarningTextBrush}"/>
                                </Border>
                                <Border Background="{StaticResource DangerSubtleBrush}" CornerRadius="4" Padding="5,2"
                                        Visibility="{x:Bind ConvertOfflineToVisibility(Channel.IsOffline), Mode=OneWay}"
                                        ToolTipService.ToolTip="{loc:Loc Key=Knob_NotRunning_Tip}">
                                    <TextBlock
                                        Style="{StaticResource MonoBadgeTextStyle}"
                                        Text="{loc:Loc Key=Knob_NotRunning}"
                                        Foreground="{StaticResource DangerTextBrush}"/>
                                </Border>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>

                    <!-- Channel settings -->
                    <Button HorizontalAlignment="Right" VerticalAlignment="Top"
                            Click="OnSettingsClick"
                            Width="30" Height="30" Padding="0" CornerRadius="8" BorderThickness="0">
                        <Button.Resources>
                            <SolidColorBrush x:Key="ButtonBackground" Color="Transparent"/>
                            <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="{StaticResource SurfaceControlColor}"/>
                            <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="{StaticResource SurfaceInsetColor}"/>
                            <SolidColorBrush x:Key="ButtonBorderBrush" Color="Transparent"/>
                            <SolidColorBrush x:Key="ButtonBorderBrushPointerOver" Color="{StaticResource StrokeDefaultColor}"/>
                            <SolidColorBrush x:Key="ButtonBorderBrushPressed" Color="Transparent"/>
                            <SolidColorBrush x:Key="ButtonForeground" Color="{StaticResource TextDisabledColor}"/>
                            <SolidColorBrush x:Key="ButtonForegroundPointerOver" Color="{StaticResource TextSecondaryColor}"/>
                            <SolidColorBrush x:Key="ButtonForegroundPressed" Color="{StaticResource TextDisabledColor}"/>
                        </Button.Resources>
                        <FontIcon Glyph="&#xE713;" FontSize="14"/>
                    </Button>
                </Grid>

                <!-- Volume slider: value fill takes the app's accent color -->
                <Slider
                    x:Name="VolumeSlider"
                    Value="{x:Bind Channel.Volume, Mode=TwoWay}"
                    Minimum="0"
                    Maximum="100"
                    Margin="0,20,0,0"
                    IsEnabled="{x:Bind ConvertOfflineToEnabled(Channel.IsOffline), Mode=OneWay}"
                    Opacity="{x:Bind ConvertMuteToOpacity(Channel.IsMuted), Mode=OneWay}">
                    <Slider.Resources>
                        <SolidColorBrush x:Key="SliderTrackFill" Color="{StaticResource SurfaceControlColor}"/>
                        <SolidColorBrush x:Key="SliderTrackFillPointerOver" Color="#2A2A31"/>
                        <SolidColorBrush x:Key="SliderTrackFillPressed" Color="{StaticResource SurfaceControlColor}"/>
                        <SolidColorBrush x:Key="SliderTrackFillDisabled" Color="{StaticResource SurfaceInsetColor}"/>
                        <!-- These three are mutated in code-behind to the channel's accent. -->
                        <SolidColorBrush x:Key="SliderTrackValueFill" Color="#D8D8D8"/>
                        <SolidColorBrush x:Key="SliderTrackValueFillPointerOver" Color="#EEEEEE"/>
                        <SolidColorBrush x:Key="SliderTrackValueFillPressed" Color="#C0C0C0"/>
                        <SolidColorBrush x:Key="SliderTrackValueFillDisabled" Color="{StaticResource SurfaceControlColor}"/>
                        <SolidColorBrush x:Key="SliderThumbBackground" Color="#FFFFFF"/>
                        <SolidColorBrush x:Key="SliderThumbBackgroundPointerOver" Color="#FFFFFF"/>
                        <SolidColorBrush x:Key="SliderThumbBackgroundPressed" Color="#D0D0D0"/>
                        <SolidColorBrush x:Key="SliderThumbBorderBrush" Color="Transparent"/>
                        <SolidColorBrush x:Key="SliderThumbBorderBrushPointerOver" Color="Transparent"/>
                        <SolidColorBrush x:Key="SliderThumbBorderBrushPressed" Color="Transparent"/>
                        <SolidColorBrush x:Key="SliderThumbBorderBrushDisabled" Color="Transparent"/>
                    </Slider.Resources>
                </Slider>

                <!-- Footer: mute toggle + volume readout -->
                <Grid Margin="0,12,0,0">

                    <Border
                        HorizontalAlignment="Left"
                        Width="34" Height="34"
                        CornerRadius="17"
                        BorderThickness="1"
                        Background="{x:Bind GetMuteBrush(Channel.IsMuted), Mode=OneWay}"
                        BorderBrush="{x:Bind GetMuteBorderBrush(Channel.IsMuted), Mode=OneWay}">
                        <Button
                            Command="{x:Bind Channel.ToggleMuteCommand}"
                            Width="34" Height="34" Padding="0" CornerRadius="17" BorderThickness="0">
                            <Button.Resources>
                                <SolidColorBrush x:Key="ButtonBackground" Color="Transparent"/>
                                <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="#18FFFFFF"/>
                                <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="#28000000"/>
                                <SolidColorBrush x:Key="ButtonBorderBrush" Color="Transparent"/>
                                <SolidColorBrush x:Key="ButtonBorderBrushPointerOver" Color="Transparent"/>
                                <SolidColorBrush x:Key="ButtonBorderBrushPressed" Color="Transparent"/>
                            </Button.Resources>
                            <FontIcon
                                Glyph="{x:Bind FormatMuteIcon(Channel.IsMuted), Mode=OneWay}"
                                FontSize="14"
                                Foreground="{x:Bind GetMuteIconBrush(Channel.IsMuted), Mode=OneWay}"/>
                        </Button>
                    </Border>

                    <TextBlock
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Text="{x:Bind FormatPercent(Channel.Volume), Mode=OneWay}"
                        FontSize="14"
                        FontFamily="Cascadia Code, Consolas"
                        FontWeight="SemiBold"
                        Foreground="{x:Bind GetPercentBrush(Channel.IsMuted), Mode=OneWay}"/>
                </Grid>

            </StackPanel>
        </Grid>
    </Border>
</UserControl>
