<UserControl
    x:Class="AudioMixerWin.Core.Controls.KnobCard"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Border CornerRadius="18" BorderThickness="1" Margin="8">
        <Border.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="0.6,1">
                <GradientStop Color="#111421" Offset="0"/>
                <GradientStop Color="#0D0F19" Offset="1"/>
            </LinearGradientBrush>
        </Border.Background>
        <Border.BorderBrush>
            <SolidColorBrush Color="#1A1D2E"/>
        </Border.BorderBrush>

        <Grid>

            <!-- Top teal shimmer line -->
            <Border VerticalAlignment="Top" Height="1" CornerRadius="18,18,0,0">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#0000D4AA" Offset="0"/>
                        <GradientStop Color="#3800D4AA" Offset="0.25"/>
                        <GradientStop Color="#3800D4AA" Offset="0.75"/>
                        <GradientStop Color="#0000D4AA" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
            </Border>

            <StackPanel Padding="18,16,18,18">

                <!-- Header: icon + name + settings -->
                <Grid>
                    <StackPanel Orientation="Horizontal" Spacing="11" VerticalAlignment="Center"
                                HorizontalAlignment="Left">

                        <!-- App icon container -->
                        <Border Width="40" Height="40" CornerRadius="10" Background="#181B2C"
                                BorderThickness="1">
                            <Border.BorderBrush>
                                <SolidColorBrush Color="#252840"/>
                            </Border.BorderBrush>
                            <Image Source="{x:Bind Channel.IconSource, Mode=OneWay}"
                                   Width="24" Height="24"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>

                        <!-- Name + knob label badge -->
                        <StackPanel VerticalAlignment="Center" Spacing="5">
                            <TextBlock
                                Text="{x:Bind Channel.DisplayName, Mode=OneWay}"
                                FontSize="15"
                                FontWeight="SemiBold"
                                FontFamily="Segoe UI Variable Display"
                                Foreground="#DDE0F0"
                                CharacterSpacing="-15"/>
                            <Border Background="#14172A" CornerRadius="4" Padding="6,2"
                                    HorizontalAlignment="Left">
                                <TextBlock
                                    Text="{x:Bind Channel.KnobLabel, Mode=OneWay}"
                                    FontSize="9"
                                    FontFamily="Cascadia Code, Consolas"
                                    Foreground="#3A4268"
                                    CharacterSpacing="100"/>
                            </Border>
                        </StackPanel>
                    </StackPanel>

                    <!-- Settings gear -->
                    <Button HorizontalAlignment="Right" VerticalAlignment="Top"
                            Click="OnSettingsClick"
                            Width="30" Height="30" Padding="0" CornerRadius="8" BorderThickness="1">
                        <Button.Resources>
                            <SolidColorBrush x:Key="ButtonBackground" Color="#14172A"/>
                            <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="#1E2236"/>
                            <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="#10131F"/>
                            <SolidColorBrush x:Key="ButtonBorderBrush" Color="#252840"/>
                            <SolidColorBrush x:Key="ButtonBorderBrushPointerOver" Color="#353860"/>
                            <SolidColorBrush x:Key="ButtonBorderBrushPressed" Color="#252840"/>
                            <SolidColorBrush x:Key="ButtonForeground" Color="#363C5C"/>
                            <SolidColorBrush x:Key="ButtonForegroundPointerOver" Color="#5060A0"/>
                            <SolidColorBrush x:Key="ButtonForegroundPressed" Color="#363C5C"/>
                        </Button.Resources>
                        <TextBlock Text="⚙" FontSize="13"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Button>
                </Grid>

                <!-- Volume slider -->
                <Slider
                    Value="{x:Bind Channel.Volume, Mode=TwoWay}"
                    Minimum="0"
                    Maximum="100"
                    Margin="0,22,0,0"
                    Opacity="{x:Bind ConvertMuteToOpacity(Channel.IsMuted), Mode=OneWay}">
                    <Slider.Resources>
                        <SolidColorBrush x:Key="SliderTrackFill" Color="#181D30"/>
                        <SolidColorBrush x:Key="SliderTrackFillPointerOver" Color="#1E2438"/>
                        <SolidColorBrush x:Key="SliderTrackFillPressed" Color="#181D30"/>
                        <SolidColorBrush x:Key="SliderTrackFillDisabled" Color="#14172A"/>
                        <SolidColorBrush x:Key="SliderTrackValueFill" Color="#00D4AA"/>
                        <SolidColorBrush x:Key="SliderTrackValueFillPointerOver" Color="#00E5B8"/>
                        <SolidColorBrush x:Key="SliderTrackValueFillPressed" Color="#00BF99"/>
                        <SolidColorBrush x:Key="SliderTrackValueFillDisabled" Color="#181D30"/>
                        <SolidColorBrush x:Key="SliderThumbBackground" Color="#E4E8FF"/>
                        <SolidColorBrush x:Key="SliderThumbBackgroundPointerOver" Color="#FFFFFF"/>
                        <SolidColorBrush x:Key="SliderThumbBackgroundPressed" Color="#C0C8E8"/>
                        <SolidColorBrush x:Key="SliderThumbBorderBrush" Color="Transparent"/>
                        <SolidColorBrush x:Key="SliderThumbBorderBrushPointerOver" Color="Transparent"/>
                        <SolidColorBrush x:Key="SliderThumbBorderBrushPressed" Color="Transparent"/>
                        <SolidColorBrush x:Key="SliderThumbBorderBrushDisabled" Color="Transparent"/>
                    </Slider.Resources>
                </Slider>

                <!-- Footer: mute button + volume % -->
                <Grid Margin="0,12,0,0">

                    <!-- Mute button: Border provides dynamic bg, Button is transparent -->
                    <Border
                        HorizontalAlignment="Left"
                        Width="34" Height="34"
                        CornerRadius="17"
                        BorderThickness="1"
                        Background="{x:Bind GetMuteBrush(Channel.IsMuted), Mode=OneWay}"
                        BorderBrush="{x:Bind GetMuteBorderBrush(Channel.IsMuted), Mode=OneWay}">
                        <Button
                            Command="{x:Bind Channel.ToggleMuteCommand}"
                            Width="34" Height="34" Padding="0" CornerRadius="17" BorderThickness="0">
                            <Button.Resources>
                                <SolidColorBrush x:Key="ButtonBackground" Color="Transparent"/>
                                <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="#18FFFFFF"/>
                                <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="#28000000"/>
                                <SolidColorBrush x:Key="ButtonBorderBrush" Color="Transparent"/>
                                <SolidColorBrush x:Key="ButtonBorderBrushPointerOver" Color="Transparent"/>
                                <SolidColorBrush x:Key="ButtonBorderBrushPressed" Color="Transparent"/>
                            </Button.Resources>
                            <TextBlock
                                Text="{x:Bind FormatMuteIcon(Channel.IsMuted), Mode=OneWay}"
                                FontSize="15"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"/>
                        </Button>
                    </Border>

                    <!-- Volume percentage -->
                    <TextBlock
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Text="{x:Bind FormatPercent(Channel.Volume), Mode=OneWay}"
                        FontSize="13"
                        FontFamily="Cascadia Code, Consolas"
                        FontWeight="SemiBold"
                        Foreground="#3D4368"/>
                </Grid>

            </StackPanel>
        </Grid>
    </Border>
</UserControl>
