<?xml version="1.0" encoding="utf-8"?>
<Application
    x:Class="AudioMixerWin.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:AudioMixerWin">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
            </ResourceDictionary.MergedDictionaries>

            <!-- Carbon theme: near-white accent replaces system colour -->
            <Color x:Key="SystemAccentColor">#C8C8C8</Color>
            <Color x:Key="SystemAccentColorDark1">#A0A0A0</Color>
            <Color x:Key="SystemAccentColorDark2">#787878</Color>
            <Color x:Key="SystemAccentColorDark3">#505050</Color>
            <Color x:Key="SystemAccentColorLight1">#D8D8D8</Color>
            <Color x:Key="SystemAccentColorLight2">#E8E8E8</Color>
            <Color x:Key="SystemAccentColorLight3">#F4F4F4</Color>

            <!-- NavigationView selection indicator -->
            <SolidColorBrush x:Key="NavigationViewSelectionIndicatorForeground" Color="#D0D0D0"/>

        </ResourceDictionary>
    </Application.Resources>
</Application>
