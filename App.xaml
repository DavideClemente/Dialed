<?xml version="1.0" encoding="utf-8"?>
<Application
    x:Class="AudioMixerWin.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:AudioMixerWin"
    xmlns:converters="using:AudioMixerWin.Core.Converters">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
                <ResourceDictionary Source="ms-appx:///Themes/Tokens.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <converters:NullToCollapsedConverter x:Key="NullToCollapsed" />
            <converters:NullToVisibleConverter x:Key="NullToVisible" />
            <converters:SelectedToBorderBrushConverter x:Key="SelectedToBorderBrush" />
            <converters:SelectedToBorderThicknessConverter x:Key="SelectedToBorderThickness" />
            <converters:BoolToVisibilityConverter x:Key="BoolToVisible" />
            <converters:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisible" />
            <converters:StringToVisibilityConverter x:Key="StringToVisible" />
            <converters:InverseBoolConverter x:Key="InverseBool" />

            <!-- Carbon theme: mint brand accent replaces the system colour so
                 sliders, toggles, focus visuals, and selection pick it up. -->
            <Color x:Key="SystemAccentColor">#34D399</Color>
            <Color x:Key="SystemAccentColorDark1">#2BB183</Color>
            <Color x:Key="SystemAccentColorDark2">#23906C</Color>
            <Color x:Key="SystemAccentColorDark3">#1A6E53</Color>
            <Color x:Key="SystemAccentColorLight1">#52DCA8</Color>
            <Color x:Key="SystemAccentColorLight2">#74E3B9</Color>
            <Color x:Key="SystemAccentColorLight3">#9EECCD</Color>

            <!-- NavigationView selection indicator -->
            <SolidColorBrush x:Key="NavigationViewSelectionIndicatorForeground" Color="#34D399"/>

            <!-- NavigationView backgrounds: opaque carbon layers so the whole
                 shell reads as one consistent surface. -->
            <SolidColorBrush x:Key="NavigationViewExpandedPaneBackground" Color="#111115"/>
            <SolidColorBrush x:Key="NavigationViewContentBackground" Color="#0D0D0F"/>
            <SolidColorBrush x:Key="NavigationViewDefaultPaneBackground" Color="#111115"/>

        </ResourceDictionary>
    </Application.Resources>
</Application>
